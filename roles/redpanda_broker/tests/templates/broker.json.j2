{
  "cluster": {
    "rpc_server_tcp_recv_buf": 65536,
    "enable_rack_awareness": "{{ rack | default(false) | lower }}"
  },
  "node": {
    "organization": "{{ organization | default('test-org') }}",
    "redpanda": {
      "data_directory": "{{ data_directory | default('/var/lib/redpanda/data') }}",
      "kafka_api": [
        {% for port in kafka_ports | default([9092]) %}
        {"address": "0.0.0.0", "port": {{ port }}}{% if not loop.last %},{% endif %}

        {% endfor %}
      ]
    }
  }
}
